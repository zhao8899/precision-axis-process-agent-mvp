# Optional OpenAI-compatible provider for MVP development testing.
# Copy this file to `.env`, then fill in the values before running Docker Compose.

MVP_CONSOLE_PORT=18080

# Examples:
# OpenAI: https://api.openai.com/v1
# Other compatible providers: use the provider's base URL ending at `/v1` if required.
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=replace-with-your-api-key
AI_PROVIDER_MODEL=gpt-4o-mini
